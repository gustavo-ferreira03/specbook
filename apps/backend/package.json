{
    "name": "backend",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js && mkdir -p dist/prompts && cp src/core/chat/prompts/*.txt dist/prompts/",
        "browser:install": "node scripts/install-mcp-browser.mjs",
        "browser:install:docker": "node scripts/install-mcp-browser.mjs --with-deps",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@earendil-works/pi-ai": "0.80.7",
        "@earendil-works/pi-coding-agent": "0.80.7",
        "@hono/node-server": "^1.19.14",
        "@hono/zod-validator": "^0.8.0",
        "@libsql/client": "^0.17.3",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@playwright/mcp": "^0.0.76",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "fast-xml-parser": "^5.2.0",
        "hono": "^4.12.23",
        "playwright-core": "^1.60.0",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/ws": "^8.18.1",
        "drizzle-kit": "^0.31.10",
        "esbuild": "^0.25.12",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3"
    }
}
